                       stretchType="RelativeToBandHeight" uuid="c1000001-0001-0001-0001-000000000007"/>
        <textElement verticalAlignment="Top"><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{nome_tecnico}]]></textFieldExpression>
      </textField>

      <!-- Data Abertura formatada -->
      <textField>
        <reportElement style="Detail" x="448" y="0" width="82" height="40" uuid="c1000001-0001-0001-0001-000000000008"/>
        <textElement verticalAlignment="Middle"><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{data_abertura} != null ? new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format($F{data_abertura}) : ""]]></textFieldExpression>
