  <!-- ══════════════════════════════════════════════════════════
       DETAIL BAND — 10 colunas com indicador visual de tempo
       ══════════════════════════════════════════════════════════ -->
  <detail>
    <band height="40" splitType="Stretch">
      <!-- Fundo zebrado — linhas pares em azul suave -->
      <rectangle>
        <reportElement x="0" y="0" width="802" height="40" backcolor="#EBF4FF"
                       stretchType="RelativeToBandHeight"
                       uuid="c1000001-0001-0001-0001-000000000001">
          <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
        </reportElement>
        <graphicElement><pen lineWidth="0.0"/></graphicElement>
      </rectangle>
      <!-- Borda inferior da linha -->
      <line>
        <reportElement x="0" y="39" width="802" height="1" forecolor="#D0E4FF" uuid="c1000001-0001-0001-0001-000000000002"/>
      </line>
      <!-- Separadores verticais nas linhas de dados -->
      <rectangle><reportElement x="26"  y="0" width="1" height="40" backcolor="#D8E9FF" stretchType="RelativeToBandHeight" uuid="c2000001-0001-0001-0001-000000000001"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="146" y="0" width="1" height="40" backcolor="#D8E9FF" stretchType="RelativeToBandHeight" uuid="c2000001-0001-0001-0001-000000000002"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="204" y="0" width="1" height="40" backcolor="#D8E9FF" stretchType="RelativeToBandHeight" uuid="c2000001-0001-0001-0001-000000000003"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="306" y="0" width="1" height="40" backcolor="#D8E9FF" stretchType="RelativeToBandHeight" uuid="c2000001-0001-0001-0001-000000000004"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="408" y="0" width="1" height="40" backcolor="#D8E9FF" stretchType="RelativeToBandHeight" uuid="c2000001-0001-0001-0001-000000000005"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="496" y="0" width="1" height="40" backcolor="#D8E9FF" stretchType="RelativeToBandHeight" uuid="c2000001-0001-0001-0001-000000000006"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="584" y="0" width="1" height="40" backcolor="#D8E9FF" stretchType="RelativeToBandHeight" uuid="c2000001-0001-0001-0001-000000000007"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="668" y="0" width="1" height="40" backcolor="#D8E9FF" stretchType="RelativeToBandHeight" uuid="c2000001-0001-0001-0001-000000000008"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="724" y="0" width="1" height="40" backcolor="#D8E9FF" stretchType="RelativeToBandHeight" uuid="c2000001-0001-0001-0001-000000000009"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>

      <!-- ── Indicadores de cor do Tempo de Atendimento ── -->
      <!-- Verde: encerrado em menos de 4h -->
      <rectangle>
        <reportElement x="585" y="1" width="82" height="38" backcolor="#C8E6C9"
                       stretchType="RelativeToBandHeight" uuid="c3000001-0001-0001-0001-000000000001">
          <printWhenExpression><![CDATA[$F{minutos_atendimento} != null && $F{minutos_atendimento} >= 0L && $F{minutos_atendimento} < 240L]]></printWhenExpression>
        </reportElement>
        <graphicElement><pen lineWidth="0.0"/></graphicElement>
      </rectangle>
      <!-- Amarelo: encerrado entre 4h e 24h -->
      <rectangle>
        <reportElement x="585" y="1" width="82" height="38" backcolor="#FFF9C4"
                       stretchType="RelativeToBandHeight" uuid="c3000001-0001-0001-0001-000000000002">
          <printWhenExpression><![CDATA[$F{minutos_atendimento} != null && $F{minutos_atendimento} >= 240L && $F{minutos_atendimento} < 1440L]]></printWhenExpression>
        </reportElement>
        <graphicElement><pen lineWidth="0.0"/></graphicElement>
      </rectangle>
      <!-- Vermelho: acima de 24h, dado legado (negativo) ou chamado ainda nao encerrado -->
      <rectangle>
        <reportElement x="585" y="1" width="82" height="38" backcolor="#FFCDD2"
                       stretchType="RelativeToBandHeight" uuid="c3000001-0001-0001-0001-000000000003">
          <printWhenExpression><![CDATA[$F{minutos_atendimento} == null || $F{minutos_atendimento} < 0L || $F{minutos_atendimento} >= 1440L]]></printWhenExpression>
        </reportElement>
        <graphicElement><pen lineWidth="0.0"/></graphicElement>
      </rectangle>

      <!-- ID (#N) -->
      <textField>
        <reportElement style="IdStyle" x="2" y="0" width="24" height="40" uuid="c1000001-0001-0001-0001-000000000003"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font size="9" isBold="true"/>
        </textElement>
        <textFieldExpression><![CDATA["#" + $F{id}]]></textFieldExpression>
      </textField>

      <!-- Título -->
      <textField isStretchWithOverflow="true">
        <reportElement style="Detail" x="30" y="4" width="112" height="32"
                       stretchType="RelativeToBandHeight" uuid="c1000001-0001-0001-0001-000000000004"/>
        <textElement verticalAlignment="Top"><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{titulo}]]></textFieldExpression>
      </textField>

      <!-- Classificação (cor condicional) -->
      <textField>
        <reportElement style="ClassStyle" x="150" y="0" width="50" height="40" uuid="c1000001-0001-0001-0001-000000000005"/>
        <textElement verticalAlignment="Middle"><font size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{classificacao}]]></textFieldExpression>
      </textField>

      <!-- Nome Cliente -->
      <textField isStretchWithOverflow="true">
        <reportElement style="Detail" x="210" y="4" width="92" height="32"
                       stretchType="RelativeToBandHeight" uuid="c1000001-0001-0001-0001-000000000006"/>
        <textElement verticalAlignment="Top"><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{nome_cliente}]]></textFieldExpression>
      </textField>

      <!-- Nome Técnico -->
      <textField isStretchWithOverflow="true">
        <reportElement style="Detail" x="312" y="4" width="92" height="32"
                       stretchType="RelativeToBandHeight" uuid="c1000001-0001-0001-0001-000000000007"/>
        <textElement verticalAlignment="Top"><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$F{nome_tecnico}]]></textFieldExpression>
      </textField>

      <!-- Data Abertura (dd/MM/yy HH:mm) -->
      <textField>
        <reportElement style="Detail" x="412" y="0" width="80" height="40" uuid="c1000001-0001-0001-0001-000000000008"/>
        <textElement verticalAlignment="Middle"><font size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{data_abertura} != null ? new java.text.SimpleDateFormat("dd/MM/yy HH:mm").format($F{data_abertura}) : ""]]></textFieldExpression>
      </textField>

      <!-- Data Fechamento (dd/MM/yy HH:mm) ou "Nao enc." -->
      <textField>
        <reportElement style="Detail" x="500" y="0" width="80" height="40" uuid="c1000001-0001-0001-0001-000000000012"/>
        <textElement verticalAlignment="Middle"><font size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{data_fechamento} != null ? new java.text.SimpleDateFormat("dd/MM/yy HH:mm").format($F{data_fechamento}) : "Nao enc."]]></textFieldExpression>
      </textField>

      <!-- Tempo de Atendimento com cor semântica (TempoStyle) -->
      <textField>
        <reportElement style="TempoStyle" x="588" y="0" width="76" height="40" uuid="c1000001-0001-0001-0001-000000000013"/>
        <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
        <textFieldExpression><![CDATA[
          ($F{minutos_atendimento} != null) ?
          (($F{minutos_atendimento} < 0L) ? "Dado legado" :
           ($F{minutos_atendimento} == 1L) ? "1 minuto" :
           ($F{minutos_atendimento} < 60L) ? ($F{minutos_atendimento} + " minutos") :
           ($F{minutos_atendimento} < 120L) ? "1 hora" :
           ($F{minutos_atendimento} < 1440L) ? ($F{minutos_atendimento}/60L + " horas") :
           ($F{minutos_atendimento} < 2880L) ? "1 dia" :
           ($F{minutos_atendimento} < 43200L) ? ($F{minutos_atendimento}/1440L + " dias") :
           ($F{minutos_atendimento} < 86400L) ? "1 mes" :
           ($F{minutos_atendimento}/43200L + " meses"))
          : "Nao enc."
        ]]></textFieldExpression>
      </textField>

      <!-- Prioridade (cor condicional) -->
      <textField>
        <reportElement style="PrioridadeStyle" x="672" y="0" width="48" height="40" uuid="c1000001-0001-0001-0001-000000000009"/>
        <textElement verticalAlignment="Middle"><font size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{prioridade}]]></textFieldExpression>
      </textField>

      <!-- Status (cor condicional) -->
      <textField>
        <reportElement style="StatusStyle" x="728" y="0" width="70" height="40" uuid="c1000001-0001-0001-0001-000000000010"/>
        <textElement verticalAlignment="Middle"><font size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <columnFooter>
    <band splitType="Stretch"/>
  </columnFooter>

