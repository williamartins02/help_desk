        <text><![CDATA[Abertura]]></text>
      </staticText>
      <staticText>
        <reportElement style="ColHeader" x="500" y="0" width="80"  height="26" uuid="b1000001-0001-0001-0001-000000000008"/>
        <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
        <text><![CDATA[Fechamento]]></text>
