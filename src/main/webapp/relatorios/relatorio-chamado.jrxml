  <!-- ══════════════════════════════════════════════════════════
       SUMMARY — Total de chamados no período
       ══════════════════════════════════════════════════════════ -->
  <summary>
    <band height="32" splitType="Stretch">
      <rectangle>
        <reportElement x="0" y="0" width="802" height="32" backcolor="#E3F2FD" uuid="e1000001-0001-0001-0001-000000000001"/>
