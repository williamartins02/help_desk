<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="relatorio-chamado"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              whenNoDataType="NoPages"
              columnWidth="802"
              leftMargin="20" rightMargin="20"
              topMargin="15" bottomMargin="15"
              uuid="e115bc59-fd0f-446b-a585-04725e27d7f0">

  <!-- ══════════════════════════════════════════════════════════
       ESTILOS
       Layout de colunas (soma = 802 px):
         ID(30) | Titulo(130) | Tipo(68) | Cliente(108) |
         Tecnico(108) | Abertura(90) | Prior.(62) | Status(88) | Obs(118)
       ══════════════════════════════════════════════════════════ -->
  <style name="Title"       fontName="Arial" fontSize="24" isBold="true"  forecolor="#FFFFFF"/>
  <style name="Subtitle"    fontName="Arial" fontSize="10"               forecolor="#BBDEFB"/>
  <style name="ColHeader"   fontName="Arial" fontSize="9"  isBold="true"  forecolor="#FFFFFF"/>
  <style name="Detail"      fontName="Arial" fontSize="9"                forecolor="#37474F"/>
  <style name="DetailSmall" fontName="Arial" fontSize="8"                forecolor="#546E7A"/>
  <style name="IdStyle"     fontName="Arial" fontSize="9"  isBold="true"  forecolor="#1565C0"/>
  <style name="Footer"      fontName="Arial" fontSize="8"                forecolor="#90A4AE"/>

  <!-- Status — cor semântica por valor -->
  <style name="StatusStyle" fontName="Arial" fontSize="9" isBold="false" forecolor="#546E7A">
    <conditionalStyle>
      <conditionExpression><![CDATA["ABERTO".equals($F{status})]]></conditionExpression>
      <style isBold="true" forecolor="#1565C0"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA["EM ANDAMENTO".equals($F{status})]]></conditionExpression>
      <style isBold="true" forecolor="#E65100"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA["ENCERRADO".equals($F{status})]]></conditionExpression>
      <style isBold="false" forecolor="#546E7A"/>
    </conditionalStyle>
  </style>

  <!-- Prioridade — cor semântica por valor -->
  <style name="PrioridadeStyle" fontName="Arial" fontSize="9" isBold="false" forecolor="#37474F">
    <conditionalStyle>
      <conditionExpression><![CDATA["BAIXA".equals($F{prioridade})]]></conditionExpression>
      <style isBold="true" forecolor="#2E7D32"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA["MEDIA".equals($F{prioridade})]]></conditionExpression>
      <style isBold="true" forecolor="#F57F17"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA["ALTA".equals($F{prioridade})]]></conditionExpression>
      <style isBold="true" forecolor="#C62828"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA["CRITICA".equals($F{prioridade})]]></conditionExpression>
      <style isBold="true" forecolor="#6A1B9A"/>
    </conditionalStyle>
  </style>

  <!-- Classificação — cor semântica por tipo -->
  <style name="ClassStyle" fontName="Arial" fontSize="9" isBold="false" forecolor="#37474F">
    <conditionalStyle>
      <conditionExpression><![CDATA["HARDWARE".equals($F{classificacao})]]></conditionExpression>
      <style isBold="true" forecolor="#1565C0"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA["SOFTWARE".equals($F{classificacao})]]></conditionExpression>
      <style isBold="true" forecolor="#00695C"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA["REDES".equals($F{classificacao})]]></conditionExpression>
      <style isBold="true" forecolor="#0277BD"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA["BANCO".equals($F{classificacao})]]></conditionExpression>
      <style isBold="true" forecolor="#4527A0"/>
    </conditionalStyle>
  </style>

  <!-- Tempo de atendimento — indicador de desempenho por cor:
       Verde  = encerrado em menos de 4h
       Amarelo = encerrado entre 4h e 24h
       Vermelho = acima de 24h ou chamado ainda aberto -->
  <style name="TempoStyle" fontName="Arial" fontSize="8" isBold="true" forecolor="#2E7D32">
    <conditionalStyle>
      <conditionExpression><![CDATA[$F{minutos_atendimento} != null && $F{minutos_atendimento} >= 240L && $F{minutos_atendimento} < 1440L]]></conditionExpression>
      <style isBold="true" forecolor="#E65100"/>
    </conditionalStyle>
    <conditionalStyle>
      <conditionExpression><![CDATA[$F{minutos_atendimento} == null || $F{minutos_atendimento} < 0L || $F{minutos_atendimento} >= 1440L]]></conditionExpression>
      <style isBold="true" forecolor="#C62828"/>
    </conditionalStyle>
  </style>

  <!-- ── Parâmetros ── -->
  <parameter name="DATA_INICIO"           class="java.lang.String"/>
  <parameter name="DATA_FIM"              class="java.lang.String"/>
  <parameter name="DATA_INICIO_FORMATADA" class="java.lang.String">
    <defaultValueExpression><![CDATA[$P{DATA_INICIO}]]></defaultValueExpression>
  </parameter>
  <parameter name="DATA_FIM_FORMATADA"    class="java.lang.String">
    <defaultValueExpression><![CDATA[$P{DATA_FIM}]]></defaultValueExpression>
  </parameter>
  <!-- null = todos os técnicos; valor inteiro = filtrar por técnico específico -->
  <parameter name="TECNICO_ID"            class="java.lang.Integer">
    <defaultValueExpression><![CDATA[null]]></defaultValueExpression>
  </parameter>

  <!-- ── Query ── -->
  <queryString>
    <![CDATA[
      SELECT
        c.id,
        c.titulo,
        CASE c.classificacao
          WHEN 0 THEN 'HARDWARE'
          WHEN 1 THEN 'SOFTWARE'
          WHEN 2 THEN 'REDES'
          WHEN 3 THEN 'BANCO'
          ELSE 'N/A'
        END AS classificacao,
        COALESCE(p_cli.nome, 'Nao atribuido') AS nome_cliente,
        COALESCE(p_tec.nome, 'Nao atribuido') AS nome_tecnico,
        c.data_abertura,
        CASE c.prioridade
          WHEN 0 THEN 'BAIXA'
          WHEN 1 THEN 'MEDIA'
          WHEN 2 THEN 'ALTA'
          WHEN 3 THEN 'CRITICA'
          ELSE 'N/A'
        END AS prioridade,
        CASE c.status
          WHEN 0 THEN 'ABERTO'
          WHEN 1 THEN 'EM ANDAMENTO'
          WHEN 2 THEN 'ENCERRADO'
          ELSE 'N/A'
        END AS status,
        c.observacoes,
        c.data_fechamento,
        CASE WHEN c.data_fechamento IS NOT NULL
             THEN EXTRACT(EPOCH FROM (c.data_fechamento - c.data_abertura))::BIGINT / 60
             ELSE NULL
        END AS minutos_atendimento
      FROM chamado c
      LEFT JOIN pessoa p_cli ON c.cliente_id = p_cli.id
      LEFT JOIN pessoa p_tec ON c.tecnico_id = p_tec.id
      WHERE c.data_abertura BETWEEN CAST('$P!{DATA_INICIO} 00:00:00' AS TIMESTAMP) AND CAST('$P!{DATA_FIM} 23:59:59' AS TIMESTAMP)
        AND ($P{TECNICO_ID} IS NULL OR c.tecnico_id = $P{TECNICO_ID})
      ORDER BY c.id
    ]]>
  </queryString>

  <!-- ── Campos ── -->
  <field name="id"            class="java.lang.Integer"/>
  <field name="titulo"        class="java.lang.String"/>
  <field name="classificacao" class="java.lang.String"/>
  <field name="nome_cliente"  class="java.lang.String"/>
  <field name="nome_tecnico"  class="java.lang.String"/>
  <field name="data_abertura" class="java.sql.Timestamp"/>
  <field name="prioridade"    class="java.lang.String"/>
  <field name="status"        class="java.lang.String"/>
  <field name="observacoes"          class="java.lang.String"/>
  <field name="data_fechamento"      class="java.sql.Timestamp"/>
  <field name="minutos_atendimento"  class="java.lang.Long"/>

  <!-- ── Variáveis ── -->
  <variable name="TOTAL_CHAMADOS" class="java.lang.Integer" calculation="Count">
    <variableExpression><![CDATA[$F{id}]]></variableExpression>
  </variable>

  <background>
    <band height="565" splitType="Stretch"/>
  </background>

  <!-- ══════════════════════════════════════════════════════════
       TITLE BAND
       ══════════════════════════════════════════════════════════ -->
  <title>
    <band height="88" splitType="Stretch">
      <!-- Fundo azul principal -->
      <rectangle>
        <reportElement x="0" y="0" width="802" height="68" backcolor="#1565C0" uuid="a1000001-0001-0001-0001-000000000001"/>
        <graphicElement><pen lineWidth="0.0"/></graphicElement>
      </rectangle>
      <!-- Barra de acento lateral -->
      <rectangle>
        <reportElement x="0" y="0" width="6" height="68" backcolor="#0D47A1" uuid="a1000001-0001-0001-0001-000000000002"/>
        <graphicElement><pen lineWidth="0.0"/></graphicElement>
      </rectangle>
      <!-- Título -->
      <staticText>
        <reportElement style="Title" x="18" y="5" width="460" height="34" uuid="a1000001-0001-0001-0001-000000000003"/>
        <textElement verticalAlignment="Middle"><font size="24" isBold="true"/></textElement>
        <text><![CDATA[Relatorio de Chamados]]></text>
      </staticText>
      <!-- Subtítulo -->
      <staticText>
        <reportElement style="Subtitle" x="18" y="42" width="420" height="18" uuid="a1000001-0001-0001-0001-000000000004"/>
        <textElement verticalAlignment="Middle"><font size="10"/></textElement>
        <text><![CDATA[Help Desk - Sistema de Gestao de Atendimento Tecnico]]></text>
      </staticText>
      <!-- Período (canto direito) -->
      <textField>
        <reportElement x="440" y="8" width="360" height="22" forecolor="#FFFFFF" uuid="a1000001-0001-0001-0001-000000000005"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font size="11" isBold="true" fontName="Arial"/>
        </textElement>
        <textFieldExpression><![CDATA["Periodo: " + $P{DATA_INICIO_FORMATADA} + "  a  " + $P{DATA_FIM_FORMATADA}]]></textFieldExpression>
      </textField>
      <!-- Data/hora de geração -->
      <textField pattern="dd/MM/yyyy 'as' HH:mm">
        <reportElement x="440" y="34" width="360" height="18" forecolor="#BBDEFB" uuid="a1000001-0001-0001-0001-000000000006"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font size="9" fontName="Arial"/>
        </textElement>
        <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
      </textField>
      <!-- Barra de informação (azul claro) -->
      <rectangle>
        <reportElement x="0" y="68" width="802" height="20" backcolor="#E3F2FD" uuid="a1000001-0001-0001-0001-000000000007"/>
        <graphicElement><pen lineWidth="0.0"/></graphicElement>
      </rectangle>
      <staticText>
        <reportElement x="8" y="68" width="540" height="20" forecolor="#1565C0" uuid="a1000001-0001-0001-0001-000000000008"/>
        <textElement verticalAlignment="Middle"><font size="8" fontName="Arial"/></textElement>
        <text><![CDATA[  Relatorio gerado automaticamente. Chamados filtrados pelo periodo e ordenados por ID.]]></text>
      </staticText>
      <staticText>
        <reportElement x="548" y="68" width="254" height="20" forecolor="#1565C0" uuid="a1000001-0001-0001-0001-000000000009"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font size="8" fontName="Arial" isBold="true"/>
        </textElement>
        <text><![CDATA[Central de Chamados - Help Desk  ]]></text>
      </staticText>
    </band>
  </title>

  <!-- ══════════════════════════════════════════════════════════
       COLUMN HEADER — 10 colunas (sem Obs, com Fechamento e Tempo)
       Layout (soma = 802 px):
         ID(26)|Titulo(120)|Tipo(58)|Cliente(102)|Tecnico(102)|
         Abertura(88)|Fechamento(88)|Tempo(84)|Prior.(56)|Status(78)
       Separadores em: 26, 146, 204, 306, 408, 496, 584, 668, 724
       ══════════════════════════════════════════════════════════ -->
  <columnHeader>
    <band height="26" splitType="Stretch">
      <!-- Fundo azul escuro -->
      <rectangle>
        <reportElement x="0" y="0" width="802" height="26" backcolor="#0D47A1" uuid="b1000001-0001-0001-0001-000000000001"/>
        <graphicElement><pen lineWidth="0.0"/></graphicElement>
      </rectangle>
      <!-- Separadores verticais no cabeçalho -->
      <rectangle><reportElement x="26"  y="3" width="1" height="20" backcolor="#1A4FA0" uuid="b2000001-0001-0001-0001-000000000001"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="146" y="3" width="1" height="20" backcolor="#1A4FA0" uuid="b2000001-0001-0001-0001-000000000002"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="204" y="3" width="1" height="20" backcolor="#1A4FA0" uuid="b2000001-0001-0001-0001-000000000003"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="306" y="3" width="1" height="20" backcolor="#1A4FA0" uuid="b2000001-0001-0001-0001-000000000004"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="408" y="3" width="1" height="20" backcolor="#1A4FA0" uuid="b2000001-0001-0001-0001-000000000005"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="496" y="3" width="1" height="20" backcolor="#1A4FA0" uuid="b2000001-0001-0001-0001-000000000006"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
