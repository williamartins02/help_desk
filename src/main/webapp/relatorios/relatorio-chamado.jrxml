      <rectangle><reportElement x="668" y="3" width="1" height="20" backcolor="#1A4FA0" uuid="b2000001-0001-0001-0001-000000000008"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <rectangle><reportElement x="724" y="3" width="1" height="20" backcolor="#1A4FA0" uuid="b2000001-0001-0001-0001-000000000009"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
      <!-- Labels das colunas -->
      <staticText>
        <reportElement style="ColHeader" x="2"   y="0" width="24"  height="26" uuid="b1000001-0001-0001-0001-000000000002"/>
